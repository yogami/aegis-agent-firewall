{
  "name": "backend",
  "version": "1.0.0",
  "description": "Aegis Agent Firewall Backend API",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon --watch src/**/*.js src/index.js",
    "test": "OPENROUTER_API_KEY=test-key NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --testPathPatterns=test/"
  },
  "jest": {
    "testMatch": [
      "**/test/**/*.spec.js",
      "**/test/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/e2e/"
    ],
    "transform": {}
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.13.6",
    "fastify": "^5.7.4",
    "ms": "^2.1.3",
    "onnxruntime-node": "^1.20.0",
    "p-map": "^7.0.4",
    "secure-json-parse": "^4.1.0"
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2024": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:sonarjs/recommended",
      "plugin:security/recommended"
    ],
    "plugins": [
      "sonarjs",
      "security"
    ],
    "rules": {
      "sonarjs/cognitive-complexity": "off",
      "sonarjs/no-duplicate-string": "warn",
      "sonarjs/no-identical-functions": "warn"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.2",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.0",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0"
  }
}
